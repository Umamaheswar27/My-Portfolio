# Dependencies — reinstalled inside container via npm ci
node_modules

# Previous build output — rebuilt inside container
build

# Git files — not needed in image
.git
.gitignore

# Environment files — should be injected at runtime, not baked in
.env
.env.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and OS files
.DS_Store
.vscode
.idea
Thumbs.db

# Docker files themselves
Dockerfile
.dockerignore

# README
README.md
